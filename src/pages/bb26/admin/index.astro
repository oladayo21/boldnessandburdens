---
export const prerender = false;

import AdminLayout from "../../../layouts/AdminLayout.astro";
import RosterTable from "../../../components/admin/RosterTable.svelte";
import { edition } from "../../../config/editions/bb26";
import { listParticipants } from "../../../lib/db";
import {
  isAuthed,
  isConfigured,
  checkPassword,
  sessionCookie,
} from "../../../lib/admin-auth";

let loginError = "";

// Only allow redirecting back to local /bb26 pages after login.
function safeNext(value: string | null): string {
  return value && value.startsWith("/bb26/") ? value : "/bb26/admin";
}

// Handle login POST.
if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const password = String(form.get("password") ?? "");
  const dest = safeNext(String(form.get("next") ?? ""));

  if (checkPassword(password)) {
    return new Response(null, {
      status: 303,
      headers: {
        location: dest,
        "set-cookie": sessionCookie(Astro.request),
      },
    });
  }

  loginError = "Incorrect password.";
}

const next = safeNext(Astro.url.searchParams.get("next"));
const configured = isConfigured();
const authed = isAuthed(Astro.request);
const participants = authed ? await listParticipants() : [];

// Project to only what the roster shows — keeps contact details (email/phone)
// out of the client island payload.
const roster = participants.map((p) => ({
  code: p.code,
  name: p.name,
  city: p.city,
  room: p.room,
  group: p.group,
  attendance: p.attendance,
  stayingOnCamp: p.stayingOnCamp,
  arrived: p.arrived,
}));
---

{!authed ? (
  <AdminLayout edition={edition} section="Sign in" bare>
    <div class="signin">
      <div class="signin__card">
        <img src="/logo-black-trim.png" alt={edition.name} width="184" height="275" />
        {!configured ? (
          <Fragment>
            <h1>Console not configured</h1>
            <p>Set the <code>ADMIN_PASSWORD</code> secret to open the console.</p>
          </Fragment>
        ) : (
          <Fragment>
            <h1>{edition.shortName} Console</h1>
            <p>Sign in to manage the conference roster.</p>
            {loginError && <p class="signin__error">{loginError}</p>}
            <form method="POST" class="signin__form">
              <input type="hidden" name="next" value={next} />
              <input
                class="input"
                name="password"
                type="password"
                placeholder="Admin password"
                autocomplete="current-password"
                required
              />
              <button type="submit" class="btn btn--primary" style="justify-content:center">Sign in</button>
            </form>
          </Fragment>
        )}
      </div>
    </div>
  </AdminLayout>
) : (
  <AdminLayout edition={edition} section="Participants" summary={String(roster.length)} fill>
    <RosterTable client:load participants={roster} days={edition.days} />
  </AdminLayout>
)}
