---
export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import { edition } from "../../../config/editions/bb26";
import { listParticipants } from "../../../lib/db";
import {
  isAuthed,
  isConfigured,
  checkPassword,
  sessionCookie,
} from "../../../lib/admin-auth";

let loginError = "";

// Handle login POST.
if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const password = String(form.get("password") ?? "");

  if (checkPassword(password)) {
    return new Response(null, {
      status: 303,
      headers: {
        location: "/bb26/admin",
        "set-cookie": sessionCookie(Astro.request),
      },
    });
  }

  loginError = "Incorrect password.";
}

const configured = isConfigured();
const authed = isAuthed(Astro.request);
const participants = authed ? await listParticipants() : [];

const saved = Astro.url.searchParams.get("saved");
---

<BaseLayout title={`Admin · ${edition.shortName}`} noindex={true} transparentHeader={true}>
  <main class={`adm ${authed ? "adm--wide" : ""}`}>
    <div class="adm__spot" aria-hidden="true"></div>

    {!configured ? (
      <div class="gate">
        <img class="gate__logo" src="/logo-black.png" alt="Boldness & Burdens Conference" width="600" height="630" />
        <p class="gate__eyebrow">{edition.shortName} · Admin</p>
        <h1 class="gate__title">Not configured</h1>
        <p class="gate__text">
          Set the <code>ADMIN_PASSWORD</code> secret to enable the admin area.
        </p>
      </div>
    ) : !authed ? (
      <div class="gate">
        <img class="gate__logo" src="/logo-black.png" alt="Boldness & Burdens Conference" width="600" height="630" />
        <p class="gate__eyebrow">{edition.shortName} · Admin</p>
        <h1 class="gate__title">Sign in</h1>
        {loginError && <p class="gate__error">{loginError}</p>}
        <form method="POST" class="gate__form">
          <input
            id="password"
            name="password"
            type="password"
            class="gate__input"
            placeholder="Admin password"
            autocomplete="current-password"
            required
          />
          <button type="submit" class="gate__btn">Sign in</button>
        </form>
      </div>
    ) : (
      <section class="adm__inner">
        <header class="adm__head">
          <img class="adm__logo" src="/logo-black.png" alt="Boldness & Burdens Conference" width="600" height="630" />
          <div>
            <p class="adm__eyebrow">{edition.shortName} · Admin</p>
            <h1 class="adm__title">Participants</h1>
          </div>
          <ul class="adm__stats">
            <li><b>{participants.length}</b><span>people</span></li>
            <li><b>{participants.filter((p) => p.room).length}</b><span>roomed</span></li>
            <li><b>{participants.filter((p) => p.checkedIn).length}</b><span>checked in</span></li>
          </ul>
        </header>

        {saved && <p class="adm__toast">Saved {saved}</p>}

        <div class="board__scroll">
          <div class="board">
            <div class="board__headrow">
              <span>ID</span>
              <span>Name</span>
              <span>Room</span>
              <span>Group</span>
              <span>Meal</span>
              <span>In</span>
              <span></span>
            </div>

            {participants.map((p) => (
              <form
                method="POST"
                action="/bb26/admin/api/update"
                class={`board__row ${p.checkedIn ? "is-in" : ""}`}
              >
                <input type="hidden" name="code" value={p.code} />
                <span class="board__code">{p.code}</span>
                <span class="board__name">
                  {p.name}
                  {p.city && <small>{p.city}</small>}
                </span>
                <input name="room" class="board__in" value={p.room ?? ""} placeholder="—" aria-label={`Room for ${p.name}`} />
                <input name="group" class="board__in" value={p.group ?? ""} placeholder="—" aria-label={`Group for ${p.name}`} />
                <input name="eating" class="board__in" value={p.eating ?? ""} placeholder="—" aria-label={`Meal group for ${p.name}`} />
                <label class="board__check" aria-label={`Checked in: ${p.name}`}>
                  <input type="checkbox" name="checked_in" checked={p.checkedIn} />
                </label>
                <button type="submit" class="board__save">Save</button>
              </form>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>
</BaseLayout>

<style>
  .adm {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(40px, 7vh, 80px) var(--space-md) var(--space-3xl);
    overflow: hidden;
  }

  .adm--wide { align-items: flex-start; }

  .adm__spot {
    position: absolute;
    top: -160px;
    left: 50%;
    width: min(120vw, 680px);
    height: 520px;
    transform: translateX(-50%);
    background: radial-gradient(closest-side, rgba(212, 135, 58, 0.16), transparent 70%);
    pointer-events: none;
  }

  /* ---- gate (login / not configured) ---- */
  .gate {
    position: relative;
    width: min(380px, 100%);
    text-align: center;
    background: #fbf8f2;
    border: 1px solid #ece2d0;
    border-radius: 18px;
    padding: var(--space-2xl) var(--space-xl);
  }

  .gate__logo { display: block; width: 130px; height: auto; margin: 0 auto -6px; }

  .gate__eyebrow {
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--color-accent-dark);
    margin: 0 0 var(--space-xs);
  }

  .gate__title {
    font-family: var(--font-display);
    font-size: 2.4rem;
    letter-spacing: 0.03em;
    color: var(--color-charcoal);
    margin: 0 0 var(--space-md);
  }

  .gate__text { color: var(--color-charcoal-light); font-size: 0.95rem; }

  .gate__error { color: var(--color-error); margin: 0 0 var(--space-md); font-size: 0.9rem; }

  .gate__form { display: flex; flex-direction: column; gap: var(--space-sm); }

  .gate__input {
    width: 100%;
    padding: 14px 16px;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-charcoal);
    background: var(--color-cream);
    border: 1.5px solid #211a12;
    border-radius: 12px;
    outline: none;
    transition: border-color 0.3s var(--ease-out);
  }

  .gate__input:focus {
    border-color: var(--color-accent);
  }

  .gate__btn {
    padding: 14px;
    font-family: var(--font-display);
    font-size: 1.2rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #1e1610;
    background: var(--color-accent);
    border: none;
    border-radius: 12px;
    cursor: pointer;
    transition: background-color 0.3s var(--ease-out), transform 0.3s var(--ease-out);
  }

  .gate__btn:hover { background: var(--color-accent-light); transform: translateY(-1px); }

  /* ---- authed board ---- */
  .adm__inner { position: relative; width: min(960px, 100%); }

  .adm__head {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-bottom: var(--space-lg);
  }

  .adm__logo { width: 66px; height: auto; flex: 0 0 auto; margin-left: -6px; }

  .adm__eyebrow {
    font-family: var(--font-body);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-accent-dark);
    margin: 0 0 2px;
  }

  .adm__title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 6vw, 3rem);
    letter-spacing: 0.03em;
    color: var(--color-charcoal);
    margin: 0;
    line-height: 0.9;
  }

  .adm__stats {
    display: flex;
    gap: var(--space-sm);
    list-style: none;
    margin: 0 0 0 auto;
    padding: 0;
  }

  .adm__stats li {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 64px;
    padding: 8px 12px;
    background: #fbf8f2;
    border: 1px solid #ece2d0;
    border-radius: 12px;
  }

  .adm__stats b {
    font-family: var(--font-display);
    font-size: 1.5rem;
    line-height: 1;
    color: var(--color-charcoal);
  }

  .adm__stats span {
    font-family: var(--font-body);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-charcoal-light);
    margin-top: 3px;
  }

  .adm__toast {
    margin: 0 0 var(--space-md);
    padding: 10px 16px;
    background: linear-gradient(180deg, #cfe3b8, #a9cf86);
    color: #1c2a1c;
    border-radius: 10px;
    font-size: 0.85rem;
    font-weight: 500;
  }

  /* ---- grid board ---- */
  .board__scroll {
    overflow-x: auto;
    background: #fbf8f2;
    border: 1px solid #ece2d0;
    border-radius: 16px;
  }

  .board { min-width: 720px; }

  .board__headrow,
  .board__row {
    display: grid;
    grid-template-columns: 92px minmax(160px, 1fr) 7rem 7rem 7rem 44px 76px;
    align-items: center;
    gap: var(--space-sm);
    padding: 10px var(--space-lg);
  }

  .board__headrow {
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-charcoal-light);
    border-bottom: 1px solid #ece2d0;
    position: sticky;
    top: 0;
    background: #f3ecdf;
  }

  .board__row {
    border-bottom: 1px solid #f0e8da;
  }

  .board__row:last-child { border-bottom: none; }

  .board__row.is-in {
    background: rgba(169, 207, 134, 0.16);
  }

  .board__code {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    color: var(--gold-3, #9c7322);
    white-space: nowrap;
  }

  .board__name {
    display: flex;
    flex-direction: column;
    font-family: var(--font-body);
    font-weight: 500;
    color: var(--color-charcoal);
    line-height: 1.2;
  }

  .board__name small {
    font-weight: 400;
    font-size: 0.72rem;
    color: var(--color-charcoal-light);
  }

  .board__in {
    width: 100%;
    min-height: 38px;
    padding: 6px 10px;
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-charcoal);
    background: var(--color-cream);
    border: 1px solid #e0d4bf;
    border-radius: 8px;
    outline: none;
    transition: border-color 0.2s var(--ease-out);
  }

  .board__in:focus {
    border-color: var(--color-accent);
  }

  .board__check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .board__check input {
    width: 22px;
    height: 22px;
    accent-color: var(--color-success);
    cursor: pointer;
  }

  .board__save {
    padding: 8px 0;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #1e1610;
    background: transparent;
    border: 1.5px solid var(--color-charcoal);
    border-radius: 999px;
    cursor: pointer;
    transition: background-color 0.2s var(--ease-out), color 0.2s var(--ease-out);
  }

  .board__save:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }

  code {
    font-family: var(--font-body);
    background: var(--color-cream-dark);
    padding: 1px 6px;
    border-radius: 4px;
  }
</style>
