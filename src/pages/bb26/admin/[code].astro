---
export const prerender = false;

import AdminLayout from "../../../layouts/AdminLayout.astro";
import ParticipantEditor from "../../../components/admin/ParticipantEditor.svelte";
import { edition } from "../../../config/editions/bb26";
import { getAdminParticipant } from "../../../lib/db";
import { isAuthed } from "../../../lib/admin-auth";
import { badgeKey } from "../../../lib/badge-pass";
import { renderSVG } from "uqr";

// Admin-only. The /bb26/admin index renders its own login form, so bounce
// unauthed visitors there with a next= so they land back here after sign-in.
if (!isAuthed(Astro.request)) {
  return Astro.redirect(`/bb26/admin?next=${encodeURIComponent(Astro.url.pathname)}`);
}

const { code } = Astro.params;
const p = code ? await getAdminParticipant(code) : null;

if (!p) {
  Astro.response.status = 404;
}

// Per-participant QR carrying a signed key — scanning (or clicking) it opens the
// gated badge directly. Shown in the editor header for the admin to present.
const badgeKeyValue = p ? await badgeKey(p.code) : "";
const badgeHref = p ? `/bb26/${p.code}?k=${badgeKeyValue}` : "";
const badgeQr = p
  ? renderSVG(`${edition.links.site}${badgeHref}`, {
      border: 2,
      blackColor: "#111827",
      whiteColor: "#ffffff",
    })
  : "";
---

{!p ? (
  <AdminLayout edition={edition} section="Not found" bare>
    <div class="signin">
      <div class="signin__card">
        <img src="/logo-black-trim.png" alt={edition.name} width="184" height="275" />
        <h1>Participant not found</h1>
        <p>No participant with that ID.</p>
        <a class="btn btn--primary" href="/bb26/admin" style="justify-content:center">Back to roster</a>
      </div>
    </div>
  </AdminLayout>
) : (
  <AdminLayout edition={edition} section={p.name} summary={p.code}>
    <a slot="actions" class="btn btn--ghost" href="/bb26/admin">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m15 18-6-6 6-6" />
      </svg>
      Roster
    </a>
    <ParticipantEditor
      client:load
      participant={p}
      days={edition.days}
      badgeQr={badgeQr}
      badgeHref={badgeHref}
    />
  </AdminLayout>
)}
