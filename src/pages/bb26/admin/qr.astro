---
export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import { edition } from "../../../config/editions/bb26";
import { isAuthed } from "../../../lib/admin-auth";
// The QR is a single, fixed code pointing at the public badge-lookup page
// (/bb26). Pre-generated at build with `npx qrcode` and inlined here as raw SVG,
// so there's no runtime QR dependency. Regenerate if the lookup URL ever changes:
//   npx qrcode -t svg -e M -q 2 -d 1e1610 -l ffffff \
//     -o src/assets/badge-qr.svg "https://boldnessandburdens.com/bb26"
import qrSvg from "../../../assets/badge-qr.svg?raw";

if (!isAuthed(Astro.request)) {
  return Astro.redirect(`/bb26/admin?next=${encodeURIComponent(Astro.url.pathname)}`);
}

const display = `${edition.links.site}/bb26`.replace(/^https?:\/\//, "");
---

<BaseLayout title={`Badge QR · Admin · ${edition.shortName}`} noindex={true} transparentHeader={true}>
  <main class="con">
    <div class="con__glow" aria-hidden="true"></div>

    <header class="rail no-print">
      <a class="rail__brand" href="/bb26/admin">
        <img class="rail__mark" src="/logo-black.png" alt="" width="600" height="630" />
        <span class="rail__word">{edition.shortName}</span>
        <span class="rail__tag">Admin</span>
      </a>
      <nav class="crumbs">
        <a href="/bb26/admin">Roster</a>
        <span aria-hidden="true">›</span>
        <b>Badge QR</b>
      </nav>
    </header>

    <section class="con__inner">
      <div class="poster">
        <img class="poster__logo" src="/logo-black.png" alt="Boldness & Burdens Conference" width="600" height="630" />
        <p class="poster__kicker">Your conference badge</p>
        <h1 class="poster__title">Scan to open your pass</h1>
        <div class="poster__qr" set:html={qrSvg}></div>
        <p class="poster__url">{display}</p>
        <p class="poster__hint">Scan the code, then search your name to open your digital badge — room, group and daily check-in.</p>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .con {
    --ink: var(--color-charcoal);
    --ink-soft: var(--color-charcoal-light);
    --paper: #fbf8f2;
    --line: #e7dcc6;
    --brass: #9c7322;

    position: relative;
    min-height: 100dvh;
    padding: 0 var(--space-md) var(--space-3xl);
    overflow: hidden;
  }

  .con__glow {
    position: absolute;
    top: -200px;
    left: 50%;
    width: min(130vw, 820px);
    height: 540px;
    transform: translateX(-50%);
    background: radial-gradient(closest-side, rgba(212, 135, 58, 0.14), transparent 72%);
    pointer-events: none;
  }

  /* ---- rail (shared look with the rest of the console) ---- */
  .rail {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    max-width: 720px;
    margin: 0 auto;
    padding: 16px 4px 14px;
    border-bottom: 1px solid var(--line);
  }
  .rail__brand { display: inline-flex; align-items: center; gap: 10px; text-decoration: none; }
  .rail__mark { width: 30px; height: auto; }
  .rail__word { font-family: var(--font-display); font-size: 1.5rem; letter-spacing: 0.06em; color: var(--ink); }
  .rail__tag {
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--brass);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 3px 9px;
  }
  .crumbs { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-body); font-size: 0.78rem; color: var(--ink-soft); }
  .crumbs a { color: var(--color-accent-dark); text-decoration: none; }
  .crumbs a:hover { text-decoration: underline; }
  .crumbs b { color: var(--ink); font-weight: 600; }

  .con__inner {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
    padding: var(--space-xl) 0 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
  }

  /* ---- printable poster ---- */
  .poster {
    width: min(420px, 100%);
    text-align: center;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 20px;
    padding: var(--space-2xl) var(--space-xl) var(--space-xl);
  }
  .poster__logo { width: 120px; height: auto; margin: 0 auto -4px; }
  .poster__kicker {
    margin: 0;
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--brass);
  }
  .poster__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 7vw, 2.6rem);
    letter-spacing: 0.03em;
    color: var(--ink);
    margin: 6px 0 var(--space-lg);
  }
  .poster__qr {
    width: min(280px, 72vw);
    margin: 0 auto;
    padding: 14px;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 14px;
  }
  .poster__qr :global(svg) { display: block; width: 100%; height: auto; }
  .poster__url {
    margin: var(--space-lg) 0 0;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--brass);
  }
  .poster__hint {
    margin: 10px auto 0;
    max-width: 30ch;
    font-family: var(--font-body);
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--ink-soft);
  }

  /* ---- print: just the poster, edge to edge ---- */
  @media print {
    .no-print { display: none !important; }
    .con { padding: 0; min-height: auto; }
    .con__glow { display: none; }
    .con__inner { padding: 0; }
    .poster { border: none; border-radius: 0; width: 100%; padding: 24px; }
  }
</style>
