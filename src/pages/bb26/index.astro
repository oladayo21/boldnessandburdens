---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { edition } from "../../config/editions/bb26";
---

<BaseLayout
  title={`Your Pass · ${edition.shortName}`}
  description="Find your digital conference pass — room, group and more."
  noindex={true}
  transparentHeader={true}
>
  <main class="desk">
    <div class="desk__spot" aria-hidden="true"></div>

    <section class="desk__inner">
      <img class="desk__logo" src="/logo-black.png" alt="Boldness & Burdens Conference" width="600" height="630" />
      <p class="desk__lead">Type your name to open your badge.</p>

      <div class="search">
        <div class="search__field">
          <svg class="search__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <circle cx="11" cy="11" r="7" />
            <path d="m21 21-4.3-4.3" />
          </svg>
          <input
            id="q"
            type="text"
            autocomplete="off"
            autocapitalize="words"
            placeholder="Start typing your name…"
            aria-label="Your name"
          />
        </div>

        <ul id="results" class="results" role="listbox" aria-label="Matching names"></ul>
        <p id="empty" class="results__empty" hidden>No match found — check your spelling or ask a steward.</p>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  const input = document.getElementById("q") as HTMLInputElement;
  const list = document.getElementById("results") as HTMLUListElement;
  const empty = document.getElementById("empty") as HTMLParagraphElement;

  let timer: ReturnType<typeof setTimeout>;
  let lastQuery = "";

  function render(items: { code: string; name: string }[]) {
    list.innerHTML = "";
    empty.hidden = items.length > 0;

    items.forEach((it, i) => {
      const li = document.createElement("li");
      const a = document.createElement("a");
      a.href = `/bb26/card/${encodeURIComponent(it.code)}`;
      a.className = "results__item";
      a.style.setProperty("--i", String(i));
      a.innerHTML = `<span class="results__name"></span><span class="results__go">open →</span>`;
      a.querySelector(".results__name")!.textContent = it.name;
      li.appendChild(a);
      list.appendChild(li);
    });
  }

  async function run(q: string) {
    try {
      const res = await fetch(`/bb26/api/search?q=${encodeURIComponent(q)}`);

      if (!res.ok) return;

      const data = (await res.json()) as { code: string; name: string }[];

      if (q !== lastQuery) return;

      render(data);
    } catch {
      /* keep previous results on network hiccup */
    }
  }

  input.addEventListener("input", () => {
    const q = input.value.trim();
    lastQuery = q;

    clearTimeout(timer);

    if (q.length < 2) {
      list.innerHTML = "";
      empty.hidden = true;

      return;
    }

    timer = setTimeout(() => run(q), 180);
  });

  input.focus();
</script>

<style>
  /* Brand fonts (Bebas Neue display + Outfit body) load via global.css. */

  .desk {
    --gold-1: #f7e7ad;
    --gold-2: #d8b256;
    --gold-3: #9c7322;

    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2xl) var(--space-md) var(--space-3xl);
    overflow: hidden;
  }

  .desk__spot {
    position: absolute;
    top: 50%;
    left: 50%;
    width: min(120vw, 720px);
    height: min(120vh, 720px);
    transform: translate(-50%, -50%);
    background: radial-gradient(closest-side, rgba(212, 135, 58, 0.18), transparent 70%);
    pointer-events: none;
  }

  .desk__inner {
    position: relative;
    width: min(440px, 100%);
    text-align: center;
  }

  .desk__logo {
    display: block;
    width: clamp(150px, 42vw, 200px);
    height: auto;
    margin: 0 auto;
    margin-bottom: calc(-1 * var(--space-md));
    animation: rise 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .desk__lead {
    margin: 0 auto;
    max-width: 30ch;
    color: var(--color-charcoal-light);
    font-size: 1.08rem;
    animation: rise 0.7s 0.1s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .search {
    margin-top: var(--space-2xl);
    animation: rise 0.7s 0.2s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .search__field {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--color-cream);
    border: 1.5px solid #211a12;
    border-radius: 14px;
    padding: 0 16px;
    text-align: left;
    transition: border-color 0.3s var(--ease-out);
  }

  .search__field:focus-within {
    border-color: var(--color-accent);
  }

  .search__icon { width: 20px; height: 20px; color: var(--gold-3); flex: 0 0 auto; }

  .search__field input {
    flex: 1;
    border: none;
    background: transparent;
    padding: 16px 0;
    font-family: var(--font-body);
    font-size: 1.1rem;
    color: #211a12;
    outline: none;
  }

  .results {
    list-style: none;
    margin: var(--space-md) 0 0;
    padding: 0;
    text-align: left;
  }

  .results__item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    margin-bottom: 8px;
    background: var(--color-cream);
    border: 1px solid var(--color-cream-dark);
    border-radius: 12px;
    color: #211a12;
    font-family: var(--font-body);
    font-size: 1.1rem;
    transition: transform 0.3s var(--ease-out), border-color 0.3s var(--ease-out), background-color 0.3s var(--ease-out);
    animation: pop 0.4s calc(var(--i) * 0.035s) cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .results__item:hover,
  .results__item:focus {
    transform: translateX(4px);
    border-color: var(--color-accent);
    background: var(--color-cream-dark);
  }

  .results__name { font-weight: 500; }

  .results__go {
    font-family: var(--font-body);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gold-3);
    white-space: nowrap;
  }

  .results__empty {
    margin: var(--space-md) 0 0;
    color: var(--color-charcoal-light);
  }

  @keyframes rise {
    0% { opacity: 0; transform: translateY(18px); }
    100% { opacity: 1; transform: none; }
  }

  @keyframes pop {
    0% { opacity: 0; transform: translateY(8px); }
    100% { opacity: 1; transform: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .desk__logo, .desk__lead, .search, .results__item { animation: none; }
  }
</style>
