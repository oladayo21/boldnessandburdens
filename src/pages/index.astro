---
import BaseLayout from '../layouts/BaseLayout.astro';

const eventJsonLd = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Boldness and Burdens Conference 2026",
  "description": "A transformative summer camp designed to equip young people with godly courage, faith and clarity to face life's challenges.",
  "startDate": "2026-07-16",
  "endDate": "2026-07-19",
  "eventStatus": "https://schema.org/EventScheduled",
  "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
  "location": {
    "@type": "Place",
    "name": "Boldness and Burdens Conference Venue",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Krimnitzer Weg 25",
      "addressLocality": "Berlin",
      "postalCode": "12527",
      "addressCountry": "DE"
    }
  },
  "image": "https://images.unsplash.com/photo-1507692049790-de58290a4334?w=1200&q=80",
  "organizer": {
    "@type": "Organization",
    "name": "Boldness and Burdens",
    "url": "https://boldnessandburdens.com"
  },
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "EUR",
    "availability": "https://schema.org/InStock",
    "url": "https://boldnessandburdens.com"
  },
  "isAccessibleForFree": true
};

// Drifting ember particles (hand-scattered so they feel organic)
const embers = [
  { left: 5, delay: 0, duration: 9, size: 4 },
  { left: 12, delay: 4.2, duration: 12, size: 3 },
  { left: 19, delay: 1.6, duration: 10, size: 5 },
  { left: 27, delay: 6.5, duration: 13, size: 3 },
  { left: 34, delay: 2.8, duration: 8, size: 4 },
  { left: 41, delay: 5.1, duration: 11, size: 3 },
  { left: 48, delay: 0.9, duration: 14, size: 5 },
  { left: 55, delay: 7.3, duration: 9, size: 3 },
  { left: 62, delay: 3.4, duration: 12, size: 4 },
  { left: 69, delay: 1.1, duration: 10, size: 3 },
  { left: 76, delay: 5.8, duration: 13, size: 5 },
  { left: 83, delay: 2.2, duration: 8, size: 3 },
  { left: 89, delay: 6.9, duration: 11, size: 4 },
  { left: 95, delay: 4.0, duration: 10, size: 3 },
];
---

<BaseLayout
  title="BBC'26 - School of the Spirit | Boldness and Burdens Conference"
  canonicalPath="/"
  transparentHeader={true}
>
  <script type="application/ld+json" set:html={JSON.stringify(eventJsonLd)} />
  <main>
    <!-- Hero Section -->
    <header class="hero">
      <div class="hero-bg">
        <img
          src="/hero-banner.jpg"
          alt="BBC'26 School of the Spirit - Boldness and Burdens Conference, July 16-19 2026, Berlin."
          loading="eager"
          width="1920"
          height="1080"
        />
      </div>
      <div class="embers" aria-hidden="true">
        {embers.map((e) => (
          <span style={`left:${e.left}%; width:${e.size}px; height:${e.size}px; animation-delay:${e.delay}s; animation-duration:${e.duration}s;`}></span>
        ))}
      </div>
    </header>

    <!-- Countdown Section -->
    <section class="countdown-section">
      <div class="container">
        <svg class="flame-mark reveal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 12c2-2.96 0-7-1-8 0 3.038-1.773 4.741-3 6-1.226 1.26-2 3.24-2 5a6 6 0 1 0 12 0c0-1.532-1.056-3.94-2-5-1.786 3-2.791 3-4 2z"/>
        </svg>
        <p class="eyebrow countdown-eyebrow reveal">The Gathering Begins In</p>
        <div class="countdown reveal" id="countdown">
          <div class="countdown-item">
            <span class="countdown-value" id="days">---</span>
            <span class="countdown-label">Days</span>
          </div>
          <div class="countdown-item">
            <span class="countdown-value" id="hours">--</span>
            <span class="countdown-label">Hours</span>
          </div>
          <div class="countdown-item">
            <span class="countdown-value" id="minutes">--</span>
            <span class="countdown-label">Minutes</span>
          </div>
          <div class="countdown-item">
            <span class="countdown-value" id="seconds">--</span>
            <span class="countdown-label">Seconds</span>
          </div>
        </div>
        <p class="countdown-date reveal">16&ndash;19 July 2026 &middot; Berlin-K&ouml;penick</p>
      </div>
    </section>

    <!-- Vision Section -->
    <section class="vision">
      <div class="container vision-head reveal">
        <div class="vision-head-lead">
          <svg class="flame-mark flame-mark--left" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 12c2-2.96 0-7-1-8 0 3.038-1.773 4.741-3 6-1.226 1.26-2 3.24-2 5a6 6 0 1 0 12 0c0-1.532-1.056-3.94-2-5-1.786 3-2.791 3-4 2z"/>
          </svg>
          <p class="eyebrow vision-eyebrow">The Vision</p>
          <h2 class="section-title vision-title">Time for Boldness &amp; Burdens Conference 2026</h2>
        </div>
        <p class="vision-intro">
          There are special times and seasons. Moments God sets apart for encounter,
          alignment, and renewal. Boldness &amp; Burdens Conference is a gathering set apart
          for young people, individuals, and families who desire more of God.
        </p>
      </div>

      <div class="vision-manifesto reveal">
        <div class="container">
          <div class="manifesto-grid">
            <figure class="manifesto-figure">
              <img
                src="https://images.unsplash.com/photo-1507692049790-de58290a4334?auto=format&fit=crop&w=900&h=1100&q=80"
                alt="Young people worshipping together with hands raised"
                loading="lazy"
                width="900"
                height="1100"
              />
            </figure>
            <div class="manifesto-copy">
              <blockquote class="manifesto-quote">
                <p>This is a <em>School of the Spirit</em> &mdash; a place of prayer, teaching, waiting, and encounter.</p>
              </blockquote>
              <p class="manifesto-thesis">A time to lay down your <em>burdens</em> &mdash; and receive <em>boldness</em>.</p>
              <p class="eyebrow manifesto-steps-label">How to Come Ready</p>
              <ol class="ready-steps">
                <li>Pray</li>
                <li>Plan</li>
                <li>Prepare</li>
                <li>Invite a friend</li>
                <li>Come expectant</li>
              </ol>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Details Section -->
    <section class="details textured">
      <div class="container">
        <svg class="flame-mark flame-mark--light reveal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 12c2-2.96 0-7-1-8 0 3.038-1.773 4.741-3 6-1.226 1.26-2 3.24-2 5a6 6 0 1 0 12 0c0-1.532-1.056-3.94-2-5-1.786 3-2.791 3-4 2z"/>
        </svg>
        <p class="eyebrow details-eyebrow reveal">Conference Details</p>
        <dl class="details-grid">
          <div class="detail-card reveal">
            <dt class="detail-label">When</dt>
            <dd class="detail-value">July 16&ndash;19<span class="detail-sub">2026</span></dd>
          </div>
          <div class="detail-card reveal delay-1">
            <dt class="detail-label">Where</dt>
            <dd class="detail-value">Berlin-K&ouml;penick<span class="detail-sub">Krimnitzer Weg 25, 12527 Berlin</span></dd>
          </div>
          <div class="detail-card reveal delay-2">
            <dt class="detail-label">Duration</dt>
            <dd class="detail-value">3 Nights<span class="detail-sub">1 Conference</span></dd>
          </div>
          <div class="detail-card reveal delay-3">
            <dt class="detail-label">Cost</dt>
            <dd class="detail-value">Free<span class="detail-sub">All welcome</span></dd>
          </div>
        </dl>
      </div>
    </section>

    <!-- Experience Section -->
    <section class="experience">
      <div class="container experience-layout">
        <div class="experience-aside reveal">
          <div class="experience-aside-inner">
            <svg class="flame-mark flame-mark--left" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 12c2-2.96 0-7-1-8 0 3.038-1.773 4.741-3 6-1.226 1.26-2 3.24-2 5a6 6 0 1 0 12 0c0-1.532-1.056-3.94-2-5-1.786 3-2.791 3-4 2z"/>
            </svg>
            <p class="eyebrow">What Awaits</p>
            <h2 class="section-title">The Experience</h2>
            <p class="experience-lede">Four days given to a single pursuit &mdash; more of God. This is the rhythm that fills them.</p>
          </div>
        </div>
        <ol class="pillars">
          <li class="pillar reveal">
            <span class="pillar-index" aria-hidden="true">I</span>
            <div class="pillar-body">
              <h3 class="pillar-title">Prayer</h3>
              <p class="pillar-desc">Extended times of personal and corporate prayer.</p>
            </div>
          </li>
          <li class="pillar reveal delay-1">
            <span class="pillar-index" aria-hidden="true">II</span>
            <div class="pillar-body">
              <h3 class="pillar-title">Worship</h3>
              <p class="pillar-desc">Spirit-led worship and spiritual songs.</p>
            </div>
          </li>
          <li class="pillar reveal delay-2">
            <span class="pillar-index" aria-hidden="true">III</span>
            <div class="pillar-body">
              <h3 class="pillar-title">Teaching</h3>
              <p class="pillar-desc">Sound teaching and impartation from the Word.</p>
            </div>
          </li>
          <li class="pillar reveal delay-3">
            <span class="pillar-index" aria-hidden="true">IV</span>
            <div class="pillar-body">
              <h3 class="pillar-title">Fellowship</h3>
              <p class="pillar-desc">Connect with like-minded believers from across the city and beyond.</p>
            </div>
          </li>
          <li class="pillar reveal delay-4">
            <span class="pillar-index" aria-hidden="true">V</span>
            <div class="pillar-body">
              <h3 class="pillar-title">Encounters</h3>
              <p class="pillar-desc">Space for God to move supernaturally.</p>
            </div>
          </li>
        </ol>
      </div>
    </section>

    <!-- What's Included Section -->
    <section class="included">
      <div class="container">
        <div class="included-grid">
          <div class="included-text reveal">
            <svg class="flame-mark flame-mark--left" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 12c2-2.96 0-7-1-8 0 3.038-1.773 4.741-3 6-1.226 1.26-2 3.24-2 5a6 6 0 1 0 12 0c0-1.532-1.056-3.94-2-5-1.786 3-2.791 3-4 2z"/>
            </svg>
            <p class="eyebrow">Come As You Are</p>
            <h2 class="section-title">What's Included</h2>
            <dl class="included-list">
              <div class="included-row">
                <dt>Accommodation</dt>
                <dd>Provided free of charge.</dd>
              </div>
              <div class="included-row">
                <dt>Meals</dt>
                <dd>One meal per day provided. Bring your own snacks if needed.</dd>
              </div>
            </dl>
          </div>
          <div class="included-bring ticked reveal delay-1">
            <h3>What to Bring</h3>
            <p class="bring-intro">Please bring your personal toiletries:</p>
            <ul class="bring-list" role="list">
              <li>Towel</li>
              <li>Blanket</li>
              <li>Soap / shower gel</li>
              <li>Toothbrush &amp; toothpaste</li>
              <li>Any personal hygiene items</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Support Section -->
    <section class="support" id="support">
      <div class="container container--narrow">
        <div class="section-head reveal">
          <svg class="flame-mark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 12c2-2.96 0-7-1-8 0 3.038-1.773 4.741-3 6-1.226 1.26-2 3.24-2 5a6 6 0 1 0 12 0c0-1.532-1.056-3.94-2-5-1.786 3-2.791 3-4 2z"/>
          </svg>
          <p class="eyebrow">Give &amp; Sow</p>
          <h2 class="section-title">Support the Conference</h2>
        </div>
        <p class="support-intro reveal">
          The conference is completely free for every participant, made possible entirely by
          the generosity of those who give. If you feel led to help us cover the costs, here
          are two ways you can give.
        </p>
        <div class="support-grid">
          <div class="support-card ticked reveal">
            <h3>PayPal</h3>
            <p>Send via PayPal to support the conference directly.</p>
            <div class="paypal-qr">
              <img src="/paypal-qr.svg" alt="PayPal QR code linking to paypal.me/HeyMakhel" width="132" height="132" loading="lazy" />
              <span>Scan to give</span>
            </div>
            <a href="https://www.paypal.me/HeyMakhel" target="_blank" rel="noopener noreferrer" class="support-link">
              <span>paypal.me/HeyMakhel</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                <path d="M7 17 17 7M9 7h8v8"/>
              </svg>
            </a>
          </div>
          <div class="support-card ticked reveal delay-1">
            <h3>Bank Transfer</h3>
            <dl class="bank-details">
              <div class="bank-row">
                <dt class="bank-label">Beneficiary</dt>
                <dd class="bank-value">Helen Chijioke</dd>
              </div>
              <div class="bank-row">
                <dt class="bank-label">IBAN</dt>
                <dd class="bank-value">DE22 1001 0178 3877 6363 76</dd>
              </div>
              <div class="bank-row">
                <dt class="bank-label">BIC / SWIFT</dt>
                <dd class="bank-value">REVODEB2</dd>
              </div>
              <div class="bank-row">
                <dt class="bank-label">Correspondent BIC</dt>
                <dd class="bank-value">CHASDEFX</dd>
              </div>
            </dl>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="footer has-rays has-rays--dark textured">
      <div class="embers" aria-hidden="true">
        {embers.map((e) => (
          <span style={`left:${e.left}%; width:${e.size}px; height:${e.size}px; animation-delay:${e.delay}s; animation-duration:${e.duration}s;`}></span>
        ))}
      </div>
      <div class="container">
        <svg class="flame-mark flame-mark--light reveal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 12c2-2.96 0-7-1-8 0 3.038-1.773 4.741-3 6-1.226 1.26-2 3.24-2 5a6 6 0 1 0 12 0c0-1.532-1.056-3.94-2-5-1.786 3-2.791 3-4 2z"/>
        </svg>
        <p class="footer-flourish reveal" aria-hidden="true">School of the Spirit</p>
        <div class="footer-content">
          <div class="footer-info">
            <p class="footer-title">BBC'26</p>
            <p>Boldness and Burdens Conference</p>
          </div>
          <div class="footer-contact">
            <p class="contact-label">Enquiries</p>
            <a href="mailto:info@boldnessandburdens.com">info@boldnessandburdens.com</a>
          </div>
        </div>
        <div class="footer-bottom">
          <p>2026 Boldness and Burdens Conference</p>
        </div>
      </div>
    </footer>
  </main>
</BaseLayout>

<style>
  /* Hero - full-bleed banner, details band below (no overlap with baked title) */
  .hero {
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 100svh;
    background: var(--color-charcoal);
    overflow: hidden;
  }

  .hero-bg {
    position: relative;
    flex: 1 1 auto;
    min-height: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform-origin: center;
    animation: heroKenBurns 22s var(--ease-out) forwards;
  }

  /* slow, barely-there drift so the static artwork breathes */
  @keyframes heroKenBurns {
    from { transform: scale(1); }
    to { transform: scale(1.07); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-bg img { animation: none; }
  }

  /* soft vignette to focus the artwork toward the centre */
  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(125% 95% at 50% 38%, transparent 58%, rgba(20, 14, 10, 0.5) 100%);
  }

  /* On phones the 16:9 banner shows at its natural height — no forced
     viewport height, so there's no dark void below it, and it flows
     straight into the countdown (useful content above the fold). */
  @media (max-width: 767px) {
    .hero {
      min-height: auto;
    }

    .hero-bg img {
      height: auto;
    }
  }

  /* ============================================================
     Atmosphere & decorative system — divine light rays, brand
     flame motif, crafted card corner ticks. Warm, sacred, refined.
     ============================================================ */

  /* light rays radiating from the top edge of a section */
  .has-rays {
    position: relative;
    overflow: hidden;
  }

  .has-rays::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: repeating-conic-gradient(
      from 90deg at 50% -6%,
      rgba(212, 135, 58, 0.07) 0deg 3deg,
      transparent 3deg 10deg
    );
    -webkit-mask-image: radial-gradient(78% 92% at 50% 0%, #000 0%, transparent 70%);
    mask-image: radial-gradient(78% 92% at 50% 0%, #000 0%, transparent 70%);
    z-index: 0;
  }

  /* rays tuned for dark sections */
  .has-rays--dark::before {
    background: repeating-conic-gradient(
      from 90deg at 50% -6%,
      rgba(230, 168, 92, 0.10) 0deg 3deg,
      transparent 3deg 10deg
    );
  }

  .has-rays > * {
    position: relative;
    z-index: 1;
  }

  @media (prefers-reduced-motion: no-preference) {
    .has-rays::before {
      animation: raysBreathe 14s ease-in-out infinite alternate;
    }
  }

  @keyframes raysBreathe {
    from { opacity: 0.7; }
    to { opacity: 1; }
  }

  /* brand flame ornament */
  .flame-mark {
    display: block;
    width: 24px;
    height: 28px;
    margin: 0 auto var(--space-md);
    color: var(--color-accent);
  }

  .flame-mark--left {
    margin-left: 0;
    margin-right: auto;
  }

  .flame-mark--light {
    color: var(--color-accent-light);
  }

  /* crafted corner ticks for premium cards */
  .ticked {
    position: relative;
  }

  .ticked::before,
  .ticked::after {
    content: '';
    position: absolute;
    width: 13px;
    height: 13px;
    border: 1.5px solid var(--color-accent);
    opacity: 0.45;
    pointer-events: none;
  }

  .ticked::before {
    top: 13px;
    left: 13px;
    border-right: 0;
    border-bottom: 0;
  }

  .ticked::after {
    bottom: 13px;
    right: 13px;
    border-left: 0;
    border-top: 0;
  }

  /* drifting ember particles */
  .embers {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 1;
  }

  .embers span {
    position: absolute;
    bottom: -8px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(230, 168, 92, 0.95), rgba(212, 135, 58, 0) 70%);
    opacity: 0;
    animation-name: emberRise;
    animation-iteration-count: infinite;
    animation-timing-function: ease-in-out;
    will-change: transform, opacity;
  }

  @keyframes emberRise {
    0% { transform: translate(0, 0) scale(0.7); opacity: 0; }
    12% { opacity: 0.9; }
    65% { opacity: 0.55; }
    100% { transform: translate(14px, -200px) scale(1.15); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .embers { display: none; }
  }

  /* fine grain texture overlay for dark sections */
  .textured {
    position: relative;
  }

  .textured > * {
    position: relative;
    z-index: 1;
  }

  .textured::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    opacity: 0.09;
    mix-blend-mode: overlay;
  }

  /* Shared section heading group */
  .section-head {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .section-head .eyebrow {
    display: block;
    margin-bottom: var(--space-md);
  }

  .section-head .divider {
    margin: var(--space-md) auto 0;
  }

  @media (min-width: 768px) {
    .section-head {
      margin-bottom: var(--space-3xl);
    }

    .section-head .divider {
      margin-top: var(--space-lg);
    }
  }

  /* Countdown Section */
  .countdown-section {
    background:
      radial-gradient(80% 130% at 50% -10%, rgba(212, 135, 58, 0.14), transparent 60%),
      var(--color-cream-dark);
    padding: var(--space-2xl) 0;
    text-align: center;
    border-bottom: 1px solid rgba(212, 135, 58, 0.16);
  }

  @media (min-width: 600px) {
    .countdown-section {
      padding: var(--space-3xl) 0;
    }
  }

  .countdown-eyebrow {
    display: block;
    margin-bottom: var(--space-lg);
  }

  .countdown {
    display: flex;
    justify-content: center;
    gap: 0;
  }

  .countdown-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1 1 0;
    max-width: 160px;
    padding: 0 clamp(var(--space-sm), 3.5vw, var(--space-xl));
    border-left: 1px solid rgba(212, 135, 58, 0.22);
  }

  .countdown-item:first-child {
    border-left: none;
  }

  .countdown-value {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 11vw, 5rem);
    font-weight: 400;
    color: var(--color-accent-dark);
    line-height: 0.85;
    font-variant-numeric: tabular-nums;
  }

  .countdown-label {
    font-size: 0.5rem;
