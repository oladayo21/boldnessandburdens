---
import BaseLayout from '../layouts/BaseLayout.astro';

const eventJsonLd = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Boldness and Burdens Conference 2026",
  "description": "A transformative summer camp designed to equip young people with godly courage, faith and clarity to face life's challenges.",
  "startDate": "2026-07-16",
  "endDate": "2026-07-19",
  "eventStatus": "https://schema.org/EventScheduled",
  "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
  "location": {
    "@type": "Place",
    "name": "Boldness and Burdens Conference Venue",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Krimnitzer Weg 25",
      "addressLocality": "Berlin",
      "postalCode": "12527",
      "addressCountry": "DE"
    }
  },
  "image": "https://images.unsplash.com/photo-1507692049790-de58290a4334?w=1200&q=80",
  "organizer": {
    "@type": "Organization",
    "name": "Boldness and Burdens",
    "url": "https://boldnessandburdens.com"
  },
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "EUR",
    "availability": "https://schema.org/InStock",
    "url": "https://boldnessandburdens.com/register"
  },
  "isAccessibleForFree": true
};
---

<BaseLayout
  title="BBC'26 - School of the Spirit | Boldness and Burdens Conference"
  canonicalPath="/"
  transparentHeader={true}
>
  <script type="application/ld+json" set:html={JSON.stringify(eventJsonLd)} />
  <main>
    <!-- Hero Section -->
    <header class="hero">
      <div class="hero-bg">
        <img
          src="/hero-banner.jpg"
          alt="BBC'26 School of the Spirit - Boldness and Burdens Conference, July 16-19 2026, Berlin."
          loading="eager"
          width="1920"
          height="1080"
        />
      </div>
    </header>

    <!-- Countdown Section -->
    <section class="countdown-section">
      <div class="container">
        <div class="countdown" id="countdown">
          <div class="countdown-item">
            <span class="countdown-value" id="days">---</span>
            <span class="countdown-label">Days</span>
          </div>
          <div class="countdown-item">
            <span class="countdown-value" id="hours">--</span>
            <span class="countdown-label">Hours</span>
          </div>
          <div class="countdown-item">
            <span class="countdown-value" id="minutes">--</span>
            <span class="countdown-label">Minutes</span>
          </div>
          <div class="countdown-item">
            <span class="countdown-value" id="seconds">--</span>
            <span class="countdown-label">Seconds</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Vision Section -->
    <section class="vision">
      <div class="container container--narrow vision-head reveal">
        <p class="eyebrow vision-eyebrow">The Vision</p>
        <h2 class="section-title">Time for Boldness &amp; Burdens Conference 2026</h2>
        <p class="vision-intro">
          There are special times and seasons. Moments God sets apart for encounter,
          alignment, and renewal. Boldness &amp; Burdens Conference is a gathering set apart
          for young people, individuals, and families who desire more of God.
        </p>
      </div>

      <blockquote class="vision-highlight reveal">
        <div class="container container--narrow">
          <p>This is a School of the Spirit &mdash; a place of prayer, teaching, waiting, and encounter.</p>
        </div>
      </blockquote>

      <div class="container container--narrow vision-body">
        <div class="vision-callout reveal">
          <p class="vision-closing">This is a time to lay down burdens and receive boldness.</p>
          <p class="vision-cta">Pray. Plan. Prepare. Invite a friend. Come expectant.</p>
        </div>
      </div>
    </section>

    <!-- Details Section -->
    <section class="details">
      <div class="container">
        <div class="details-grid">
          <div class="detail-card reveal">
            <svg class="detail-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="4" width="18" height="18" rx="2"/>
              <path d="M16 2v4M8 2v4M3 10h18"/>
              <path d="M8 14h.01M12 14h.01M16 14h.01M8 18h.01M12 18h.01"/>
            </svg>
            <div class="detail-text">
              <span class="detail-label">When</span>
              <h3 class="detail-value">July 16-19</h3>
              <p class="detail-sub">2026</p>
            </div>
          </div>
          <div class="detail-card reveal delay-1">
            <svg class="detail-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
              <circle cx="12" cy="9" r="2.5"/>
            </svg>
            <div class="detail-text">
              <span class="detail-label">Where</span>
              <h3 class="detail-value">Berlin-Köpenick</h3>
              <p class="detail-sub">Krimnitzer Weg 25<br/>12527 Berlin</p>
            </div>
          </div>
          <div class="detail-card reveal delay-2">
            <svg class="detail-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"/>
            </svg>
            <div class="detail-text">
              <span class="detail-label">Duration</span>
              <h3 class="detail-value">3 Nights</h3>
              <p class="detail-sub">1 Conference</p>
            </div>
          </div>
          <div class="detail-card reveal delay-3">
            <svg class="detail-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M20 12v6a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-6"/>
              <path d="M12 3v12M12 3l4 4M12 3 8 7"/>
              <rect x="2" y="9" width="20" height="5" rx="1"/>
            </svg>
            <div class="detail-text">
              <span class="detail-label">Cost</span>
              <h3 class="detail-value">Free</h3>
              <p class="detail-sub">Registration required</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Experience Section -->
    <section class="experience">
      <div class="container">
        <h2 class="section-title reveal">The Experience</h2>
        <div class="divider"></div>
        <div class="experience-grid">
          <div class="experience-card reveal">
            <svg class="experience-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 5c-1.5-2-4-2.5-6-1s-2.5 4.5-1 7c1 1.5 7 7 7 7s6-5.5 7-7c1.5-2.5 1-5.5-1-7s-4.5-1-6 1z"/>
              <path d="M12 5v4M10 7h4"/>
            </svg>
            <h3>Prayer</h3>
            <p>Extended times of personal and corporate prayer</p>
          </div>
          <div class="experience-card reveal delay-1">
            <svg class="experience-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="3"/>
              <path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
            </svg>
            <h3>Worship</h3>
            <p>Spirit-led worship and spiritual songs</p>
          </div>
          <div class="experience-card reveal delay-2">
            <svg class="experience-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M4 5a2 2 0 0 1 2-2h6v16H6a2 2 0 0 0-2 2z"/>
              <path d="M20 5a2 2 0 0 0-2-2h-6v16h6a2 2 0 0 1 2 2z"/>
            </svg>
            <h3>Teaching</h3>
            <p>Sound teaching and impartation from the Word</p>
          </div>
          <div class="experience-card reveal delay-3">
            <svg class="experience-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="9" cy="7" r="4"/>
              <path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/>
              <circle cx="17" cy="10" r="3"/>
              <path d="M21 21v-1.5a3 3 0 0 0-3-3h-1"/>
            </svg>
            <h3>Fellowship</h3>
            <p>Connect with like-minded believers</p>
          </div>
          <div class="experience-card reveal delay-4">
            <svg class="experience-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/>
            </svg>
            <h3>Encounters</h3>
            <p>Space for God to move supernaturally</p>
          </div>
        </div>
      </div>
    </section>

    <!-- What's Included Section -->
    <section class="included">
      <div class="container">
        <div class="included-grid">
          <div class="included-text reveal">
            <h2 class="section-title">What's Included</h2>
            <div class="divider"></div>
            <ul class="included-list">
              <li>
                <strong>Accommodation</strong>
                <span>Provided free of charge</span>
              </li>
              <li>
                <strong>Meals</strong>
                <span>One meal per day provided. Bring your own snacks if needed</span>
              </li>
            </ul>
          </div>
          <div class="included-bring reveal delay-1">
            <h3>What to Bring</h3>
            <p class="bring-intro">Please bring your personal toiletries:</p>
            <ul class="bring-list">
              <li>Towel</li>
              <li>Blanket</li>
              <li>Soap / shower gel</li>
              <li>Toothbrush & toothpaste</li>
              <li>Any personal hygiene items</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Support Section -->
    <section class="support" id="support">
      <div class="container container--narrow">
        <h2 class="section-title reveal">Support the Conference</h2>
        <div class="divider"></div>
        <p class="support-intro">
          The conference is completely free for every participant, made possible entirely by
          the generosity of those who give. If you feel led to help us cover the costs, here
          are two ways you can give.
        </p>
        <div class="support-grid">
          <div class="support-card reveal">
            <h3>PayPal</h3>
            <p>Send via PayPal to support the conference directly.</p>
            <a href="https://www.paypal.me/HeyMakhel" target="_blank" rel="noopener noreferrer" class="btn btn--primary">
              <svg class="paypal-icon" width="20" height="24" viewBox="0 0 24 32" fill="none">
                <path d="M20.4 7.8c-.1-.7-.3-1.3-.6-1.9C18.6 3.5 15.8 2 12.3 2H4.8c-.5 0-.9.4-1 .8L1 25.2c0 .4.2.7.6.7h4.5l1.1-7.1-.1.2c.1-.5.5-.8 1-.8h2c4 0 7.2-1.6 8.1-6.4.1-.1.1-.3.1-.4.3-1.6.2-2.7-.5-3.6z" fill="#27346A"/>
                <path d="M20.4 7.8c-.1-.7-.3-1.3-.6-1.9C18.6 3.5 15.8 2 12.3 2H4.8c-.5 0-.9.4-1 .8L1 25.2c0 .4.2.7.6.7h4.5l1.1-7.1-.1.2c.1-.5.5-.8 1-.8h2c4 0 7.2-1.6 8.1-6.4.1-.1.1-.3.1-.4" fill="#27346A"/>
                <path d="M9.2 7.9c0-.3.2-.5.4-.7.1-.1.3-.1.4-.1h6.2c.7 0 1.4.1 2 .2.2 0 .3.1.5.1.2.1.3.1.5.2.1 0 .2.1.2.1.3.1.5.3.7.5.3-1.6 0-2.7-.7-3.7C18.2 3.1 15.5 1.7 12 1.7H4.5c-.5 0-1 .4-1 .9L.6 25.3c-.1.4.3.8.7.8h4.5l1.1-7.2 2.3-11z" fill="#2790C3"/>
                <path d="M20.9 11.4c-.9 4.7-4 6.3-8 6.3h-2c-.5 0-.9.4-1 .9l-1 6.6c0 .3.2.6.5.6h3.6c.4 0 .8-.3.9-.7v-.2l.7-4.2v-.2c.1-.4.4-.7.9-.7h.5c3.5 0 6.3-1.4 7.1-5.6.3-1.7.2-3.2-.7-4.2-.3-.3-.6-.5-.9-.6-.1.7-.3 1.3-.6 2z" fill="#1F264F"/>
              </svg>
              <span>Give via PayPal</span>
            </a>
          </div>
          <div class="support-card reveal delay-1">
            <h3>Bank Transfer</h3>
            <div class="bank-details">
              <div class="bank-row">
                <span class="bank-label">Beneficiary</span>
                <span class="bank-value">Helen Chijioke</span>
              </div>
              <div class="bank-row">
                <span class="bank-label">IBAN</span>
                <span class="bank-value">DE22 1001 0178 3877 6363 76</span>
              </div>
              <div class="bank-row">
                <span class="bank-label">BIC / SWIFT</span>
                <span class="bank-value">REVODEB2</span>
              </div>
              <div class="bank-row">
                <span class="bank-label">Correspondent BIC</span>
                <span class="bank-value">CHASDEFX</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
      <div class="container">
        <div class="footer-cta">
          <p class="footer-cta-text">This conference is free for every young believer. If you feel led, help us make it happen.</p>
          <a href="#support" class="btn btn--primary">Support the Conference</a>
        </div>
        <div class="footer-content">
          <div class="footer-info">
            <p class="footer-title">BBC'26</p>
            <p>Boldness and Burdens Conference</p>
          </div>
          <div class="footer-contact">
            <p class="contact-label">Enquiries</p>
            <a href="mailto:info@boldnessandburdens.com">info@boldnessandburdens.com</a>
          </div>
        </div>
        <div class="footer-bottom">
          <p>2026 Boldness and Burdens Conference</p>
        </div>
      </div>
    </footer>
  </main>
</BaseLayout>

<style>
  /* Hero - full-bleed banner, details band below (no overlap with baked title) */
  .hero {
    display: flex;
    flex-direction: column;
    min-height: 100svh;
    background: var(--color-charcoal);
    overflow: hidden;
  }

  .hero-bg {
    position: relative;
    flex: 1 1 auto;
    min-height: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform-origin: center;
    animation: heroKenBurns 22s var(--ease-out) forwards;
  }

  /* slow, barely-there drift so the static artwork breathes */
  @keyframes heroKenBurns {
    from { transform: scale(1); }
    to { transform: scale(1.07); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-bg img { animation: none; }
  }

  /* soft vignette to focus the artwork toward the centre */
  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(125% 95% at 50% 38%, transparent 58%, rgba(20, 14, 10, 0.5) 100%);
  }

  /* Countdown Section */
  .countdown-section {
    background: var(--color-cream-dark);
    padding: var(--space-lg) 0;
  }

  @media (min-width: 600px) {
    .countdown-section {
      padding: var(--space-2xl) 0;
    }
  }

  .countdown {
    display: flex;
    justify-content: center;
    gap: var(--space-lg);
  }

  @media (min-width: 600px) {
    .countdown {
      gap: var(--space-2xl);
    }
  }

  .countdown-item {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .countdown-value {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 6vw, 3rem);
    font-weight: 400;
    color: var(--color-accent-dark);
    line-height: 1;
  }

  .countdown-label {
    font-size: 0.5rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-charcoal-light);
    margin-top: var(--space-xs);
  }

  @media (min-width: 600px) {
    .countdown-label {
      font-size: 0.625rem;
      letter-spacing: 0.2em;
      margin-top: var(--space-sm);
    }
  }

  /* Vision Section */
  .vision {
    padding: var(--space-3xl) 0 0;
  }

  .vision-head { text-align: center; }

  .vision-eyebrow {
    margin-bottom: var(--space-md);
  }

  .vision .section-title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: var(--space-lg);
    text-wrap: balance;
  }

  .vision-intro {
    font-size: clamp(1rem, 2vw, 1.15rem);
    line-height: 1.8;
    color: var(--color-charcoal-light);
    margin: 0;
  }

  /* focal pull-quote on a warm ember band */
  .vision-highlight {
    margin: var(--space-3xl) 0;
    padding: var(--space-3xl) 0;
    background:
      radial-gradient(60% 140% at 50% 50%, rgba(230, 168, 92, 0.16), transparent 70%),
      var(--color-cream-dark);
    border-top: 1px solid rgba(212, 135, 58, 0.2);
    border-bottom: 1px solid rgba(212, 135, 58, 0.2);
  }

  .vision-highlight p {
    position: relative;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.75rem, 4.5vw, 3rem);
    line-height: 1.05;
    letter-spacing: 0.02em;
    text-align: center;
    text-wrap: balance;
    color: var(--color-charcoal);
    margin: 0;
  }

  .vision-highlight p::before {
    content: '“';
    color: var(--color-accent);
  }
  .vision-highlight p::after {
    content: '”';
    color: var(--color-accent);
  }

  .vision-body { padding-bottom: var(--space-3xl); }

  .vision-callout {
    text-align: center;
    border-top: 1px solid rgba(212, 135, 58, 0.25);
    padding-top: var(--space-2xl);
  }

  .vision-closing {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: clamp(1.0625rem, 2.4vw, 1.35rem);
    color: var(--color-charcoal);
    margin-bottom: var(--space-md);
  }

  .vision-cta {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    letter-spacing: 0.04em;
    color: var(--color-accent-dark);
    margin: 0;
  }

  @media (min-width: 768px) {
    .vision { padding-top: var(--space-4xl); }
  }

  /* Details Section */
  .details {
    background: var(--color-charcoal);
    color: var(--color-cream);
    padding: var(--space-3xl) 0;
  }

  .details-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 600px) {
    .details-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-xl);
    }
  }

  @media (min-width: 900px) {
    .details-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-2xl);
    }
  }

  .detail-card {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  @media (min-width: 900px) {
    .detail-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 0;
    }
  }

  .detail-icon {
    width: 28px;
    height: 28px;
    min-width: 28px;
    color: var(--color-accent);
  }

  @media (min-width: 900px) {
    .detail-icon {
      width: 32px;
      height: 32px;
      min-width: 32px;
      margin-bottom: var(--space-md);
    }
  }

  .detail-text {
    flex: 1;
  }

  @media (min-width: 900px) {
    .detail-text {
      text-align: center;
    }
  }

  .detail-label {
    display: block;
    font-size: 0.5rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-xs);
  }

  @media (min-width: 768px) {
    .detail-label {
      font-size: 0.625rem;
      letter-spacing: 0.2em;
      margin-bottom: var(--space-sm);
    }
  }

  .detail-value {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 400;
    margin-bottom: 2px;
    color: var(--color-cream);
  }

  @media (min-width: 768px) {
    .detail-value {
      font-size: clamp(1.125rem, 2vw, 1.375rem);
      margin-bottom: var(--space-xs);
    }
  }

  .detail-sub {
    font-size: 0.75rem;
    color: rgba(250, 248, 245, 0.6);
    margin: 0;
    line-height: 1.5;
  }

  @media (min-width: 768px) {
    .detail-sub {
      font-size: 0.8125rem;
      line-height: 1.6;
    }
  }

  /* Experience Section */
  .experience {
    padding: var(--space-3xl) 0;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 400;
    text-align: center;
  }

  .experience .divider {
    margin: var(--space-md) auto var(--space-xl);
  }

  @media (min-width: 768px) {
    .experience .divider {
      margin: var(--space-lg) auto var(--space-2xl);
    }
  }

  .experience-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 480px) {
    .experience-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 900px) {
    .experience-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-xl);
    }
  }

  .experience-card {
    padding: var(--space-lg);
    background: var(--color-cream-dark);
    text-align: center;
  }

  @media (min-width: 768px) {
    .experience-card {
      padding: var(--space-xl) var(--space-lg);
    }
  }

  .experience-icon {
    width: 32px;
    height: 32px;
    color: var(--color-accent);
    margin: 0 auto var(--space-sm);
    display: block;
  }

  @media (min-width: 768px) {
    .experience-icon {
      width: 40px;
      height: 40px;
      margin-bottom: var(--space-md);
    }
  }

  .experience-card h3 {
    font-family: var(--font-display);
    font-size: 1rem;
