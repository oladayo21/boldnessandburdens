---
interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalPath?: string;
  noindex?: boolean;
  transparentHeader?: boolean;
}

const SITE_URL = "https://boldnessandburdens.com";
const DEFAULT_IMAGE = `${SITE_URL}/hero.jpg`;
const DEFAULT_DESCRIPTION = "Boldness and Burdens Conference 2026 - A transformative youth prayer conference in Berlin. July 16-19, 2026. Free registration.";

const {
  title,
  description = DEFAULT_DESCRIPTION,
  image = DEFAULT_IMAGE,
  canonicalPath = "",
  noindex = false,
  transparentHeader = false
} = Astro.props;

const canonicalURL = `${SITE_URL}${canonicalPath}`;
const fullTitle = title.includes("BBC'26") ? title : `${title} | BBC'26`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content="Boldness and Burdens Conference" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Theme -->
    <meta name="theme-color" content="#faf8f5" />
    <meta name="msapplication-TileColor" content="#faf8f5" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <title>{fullTitle}</title>
  </head>
  <body>
    {!transparentHeader && (
      <header class="site-header">
        <div class="site-header__inner">
          <a href="/" class="site-header__logo" aria-label="Boldness and Burdens Conference - home">
            <img
              src="/logo-black.png"
              alt="Boldness and Burdens Conference"
              width="600"
              height="630"
            />
          </a>
        </div>
      </header>
    )}
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-cream);
    border-bottom: 1px solid var(--color-cream-dark);
  }

  .site-header__inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: var(--space-sm) var(--space-lg);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .site-header__logo img {
    height: 52px;
    width: auto;
    display: block;
  }

  @media (max-width: 480px) {
    .site-header__logo img {
      height: 44px;
    }
  }
</style>
